<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.bolwarratechnologies.this_note</id>

  <name>This Note</name>
  <summary>Offline private notes</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>LicenseRef-proprietary=https://bolwarratechnologies.com/license</project_license>

  <developer id="com.bolwarratechnologies">
    <name>Bolwarra Technologies</name>
  </developer>

  <description>
    <p>
      Write freely knowing your notes never leave your device. No account required,
      no internet connection, no data sent anywhere — ever.
    </p>
    <ul>
      <li>Per-note password protection keeps sensitive notes locked</li>
      <li>Organize with nested folders, tags, and note-to-note links</li>
      <li>Mind-map your ideas visually with the built-in Synapse canvas</li>
      <li>Writing stats: word count, reading time, and tracked writing time</li>
      <li>12 themes, rich text formatting, and a clean three-panel layout</li>
    </ul>
  </description>

  <launchable type="desktop-id">com.bolwarratechnologies.this_note.desktop</launchable>

  <screenshots>
    <screenshot type="default">
      <caption>Three-panel layout with note tree, editor, and writing stats</caption>
