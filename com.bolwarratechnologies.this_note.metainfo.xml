    </screenshot>
    <screenshot>
      <caption>Nested folders, notes, and tags — organized your way</caption>
      <image>https://bolwarratechnologies.com/screenshots/2.png</image>
    </screenshot>
    <screenshot>
      <caption>No account. No cloud. No compromise.</caption>
      <image>https://bolwarratechnologies.com/screenshots/3.png</image>
    </screenshot>
    <screenshot>
      <caption>Notes, to-dos, and mind maps in one place</caption>
      <image>https://bolwarratechnologies.com/screenshots/4.png</image>
    </screenshot>
    <screenshot>
      <caption>Clean, focused writing environment</caption>
      <image>https://bolwarratechnologies.com/screenshots/5.png</image>
    </screenshot>
  </screenshots>

  <branding>
    <color type="primary" scheme_preference="light">#e74c3c</color>
    <color type="primary" scheme_preference="dark">#8e1a0e</color>
